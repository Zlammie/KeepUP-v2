<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>BuildRootz Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="/assets/css/main.css" />
    <link rel="stylesheet" href="/assets/css/pages/buildrootz-dashboard.css" />
  </head>
  <body>
    <%- include('../../partials/nav') %>
    <%- include('../../partials/top-nav-buildrootz') %>

    <main class="container py-4 brz-dashboard-page">
      <header class="mb-4">
        <p class="text-uppercase text-muted small mb-1">BuildRootz</p>
        <h1 class="h3 mb-2">Dashboard</h1>
        <p class="text-muted mb-0">
          Start here for BuildRootz operations, then jump into the existing tools below.
        </p>
      </header>

      <section class="mb-4" aria-label="BuildRootz summary">
        <div class="row g-3">
          <div class="col-12 col-md-6 col-xl-3">
            <article class="card shadow-sm border-0 h-100 brz-summary-card">
              <div class="card-body">
                <p class="text-uppercase text-muted small mb-1">Communities</p>
                <p class="display-6 mb-0"><%= Number(summary?.totalCommunities || 0).toLocaleString() %></p>
              </div>
            </article>
          </div>
          <div class="col-12 col-md-6 col-xl-3">
            <article class="card shadow-sm border-0 h-100 brz-summary-card">
              <div class="card-body">
                <div class="d-flex align-items-start justify-content-between gap-2">
                  <div>
                    <p class="text-uppercase text-muted small mb-1">Mapped</p>
                    <p class="display-6 mb-0"><%= Number(summary?.mappedCommunities || 0).toLocaleString() %></p>
                    <p class="small text-muted mb-0">Unmapped: <%= Number(summary?.unmappedCommunities || 0).toLocaleString() %></p>
                  </div>
                  <% if (canAccessMapping) { %>
                    <a
                      href="/admin/buildrootz/communities"
                      class="brz-plus-btn"
                      aria-label="Open BRZ mapping"
                      title="Open BRZ mapping"
                    >
                      <img src="/assets/icons/add-circle-icon.svg" alt="" />
                    </a>
                  <% } else { %>
                    <button
                      type="button"
                      class="brz-plus-btn is-disabled"
                      aria-label="BRZ mapping requires Manager or higher role"
                      title="BRZ mapping requires Manager or higher role"
                      disabled
                    >
                      <img src="/assets/icons/add-circle-icon.svg" alt="" />
                    </button>
                  <% } %>
                </div>
              </div>
            </article>
          </div>
          <div class="col-12 col-md-6 col-xl-3">
            <article class="card shadow-sm border-0 h-100 brz-summary-card">
              <div class="card-body">
                <p class="text-uppercase text-muted small mb-1">Lots</p>
                <p class="display-6 mb-0"><%= Number(summary?.totalLots || 0).toLocaleString() %></p>
              </div>
            </article>
          </div>
          <div class="col-12 col-md-6 col-xl-3">
            <article class="card shadow-sm border-0 h-100 brz-summary-card">
              <div class="card-body">
                <p class="text-uppercase text-muted small mb-1">Published</p>
                <p class="display-6 mb-0"><%= Number(summary?.publishedLots || 0).toLocaleString() %></p>
                <p class="small text-muted mb-0">Not Published: <%= Number(summary?.unpublishedLots || 0).toLocaleString() %></p>
              </div>
            </article>
          </div>
        </div>
      </section>

      <section aria-label="BuildRootz quick links">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
          <h2 class="h5 mb-0">Quick Links</h2>
          <p class="text-muted small mb-0">Existing tools remain unchanged.</p>
        </div>

        <div class="row g-3">
          <% (quickLinks || []).forEach((item) => { %>
            <div class="col-12 col-md-6 col-xl-4">
              <article class="card shadow-sm border-0 h-100 brz-link-card">
                <div class="card-body d-flex flex-column">
                  <div class="d-flex align-items-center justify-content-between mb-2">
                    <h3 class="h6 mb-0"><%= item.title %></h3>
                    <% if (!item.enabled && item.requires) { %>
                      <span class="badge text-bg-light"><%= item.requires %></span>
                    <% } %>
                  </div>
                  <p class="text-muted small mb-3"><%= item.description %></p>
                  <div class="mt-auto">
                    <% if (item.enabled) { %>
                      <a href="<%= item.href %>" class="btn btn-primary btn-sm">Open</a>
                    <% } else { %>
                      <button type="button" class="btn btn-outline-secondary btn-sm" disabled>Restricted</button>
                    <% } %>
                  </div>
                </div>
              </article>
            </div>
          <% }) %>
        </div>
      </section>

      <% if (permissions && (permissions.isCompanyAdmin || permissions.isSuperAdmin)) { %>
        <section class="mt-4" aria-label="Inventory publish audit">
          <div class="card shadow-sm border-0">
            <div class="card-body">
              <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
                <h2 class="h5 mb-0">Inventory Publish Audit</h2>
                <small class="text-muted" id="brzDashboardPublishAuditStatus"></small>
              </div>
              <div class="table-responsive">
                <table class="table table-sm align-middle mb-0">
                  <thead>
                    <tr>
                      <th>Time</th>
                      <th>Mode</th>
                      <th>Scope</th>
                      <th>Published</th>
                      <th>Deactivated</th>
                      <th>Warnings</th>
                      <th></th>
                    </tr>
                  </thead>
                  <tbody id="brzDashboardPublishAuditBody">
                    <tr>
                      <td colspan="7" class="text-muted">Loading publish audit...</td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </section>
      <% } %>
    </main>
    <% if (permissions && (permissions.isCompanyAdmin || permissions.isSuperAdmin)) { %>
      <script src="/public/js/admin/buildrootz-dashboard.js" nonce="<%= cspNonce %>" defer></script>
    <% } %>
  </body>
</html>
