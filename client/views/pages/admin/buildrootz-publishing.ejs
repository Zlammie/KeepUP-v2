<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>BuildRootz Publishing</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="/assets/css/main.css" />
    <link rel="stylesheet" href="/assets/css/pages/buildrootz-publishing.css" />
  </head>
  <body>
    <% const sectionMeta = publishingSectionMeta || {}; %>
    <% const sectionData = publishingSectionData || {}; %>
    <% const bootstrapPayload = publishingBootstrap || { sections: sectionData }; %>
    <% const bootstrapPayloadJson = JSON.stringify(bootstrapPayload).replace(/</g, '\\u003c'); %>
    <%- include('../../partials/nav') %>
    <%- include('../../partials/top-nav-buildrootz') %>

    <main class="main-content p-4 brz-publishing-page">
      <header class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
        <div>
          <p class="text-uppercase text-muted small mb-1">BuildRootz</p>
          <h1 class="h4 mb-1">BuildRootz Publishing</h1>
          <p class="text-muted mb-0">
            KeepUp is the source of truth. Publish sends an internal bundle to BuildRootz with canonical mapped IDs.
          </p>
        </div>
        <a class="btn btn-outline-secondary btn-sm" href="/admin/brz/lot-operations">Open Lot Operations</a>
      </header>

      <section class="card shadow-sm mb-4 brz-workflow-nav-card">
        <div class="card-body py-3 d-flex justify-content-between align-items-center flex-wrap gap-3">
          <div>
            <p class="brz-workflow-step mb-1">Workflow</p>
            <h2 class="h6 mb-0">Choose the section you are working on</h2>
          </div>
          <div class="btn-group brz-workflow-switcher" role="tablist" aria-label="Publishing workflow sections">
            <button
              class="btn btn-outline-secondary active"
              type="button"
              role="tab"
              id="brzWorkflowTabBuilderPlans"
              data-brz-workflow-tab="builder-plans"
              aria-selected="true"
              aria-controls="brzWorkflowPanelBuilderPlans"
            >
              Builder &amp; Plans
            </button>
            <button
              class="btn btn-outline-secondary"
              type="button"
              role="tab"
              id="brzWorkflowTabCommunities"
              data-brz-workflow-tab="communities"
              aria-selected="false"
              aria-controls="brzWorkflowPanelCommunities"
            >
              Communities
            </button>
            <button
              class="btn btn-outline-secondary"
              type="button"
              role="tab"
              id="brzWorkflowTabPublish"
              data-brz-workflow-tab="publish"
              aria-selected="false"
              aria-controls="brzWorkflowPanelPublish"
            >
              Publish
            </button>
          </div>
        </div>
      </section>

      <section
        id="brzWorkflowPanelBuilderPlans"
        class="brz-workflow-panel"
        data-brz-workflow-panel="builder-plans"
        role="tabpanel"
        aria-labelledby="brzWorkflowTabBuilderPlans"
      >
        <%- include('partials/buildrootz-publishing/builder-profile-section', {
          sectionMeta: sectionMeta.builderProfile || {},
          sectionData: sectionData.builderProfile || {}
        }) %>
        <div class="brz-workflow-subdivider mb-3">
          <h3 class="h6 mb-1">Plan Verification</h3>
          <p class="small text-muted mb-0">Review floor plan media and pricing defaults before moving to communities.</p>
        </div>
        <%- include('partials/buildrootz-publishing/floor-plan-section', {
          sectionMeta: sectionMeta.floorPlanCatalog || {},
          sectionData: sectionData.floorPlanCatalog || {}
        }) %>
      </section>

      <section
        id="brzWorkflowPanelCommunities"
        class="brz-workflow-panel"
        data-brz-workflow-panel="communities"
        role="tabpanel"
        aria-labelledby="brzWorkflowTabCommunities"
        hidden
      >
        <%- include('partials/buildrootz-publishing/community-setup-section', {
          sectionMeta: sectionMeta.communityPublishing || {},
          sectionData: sectionData.communityPublishing || {}
        }) %>
      </section>

      <section
        id="brzWorkflowPanelPublish"
        class="brz-workflow-panel"
        data-brz-workflow-panel="publish"
        role="tabpanel"
        aria-labelledby="brzWorkflowTabPublish"
        hidden
      >
        <%- include('partials/buildrootz-publishing/publish-summary-section', {
          sectionMeta: sectionMeta.publishSummary || {},
          sectionData: sectionData.publishSummary || {}
        }) %>
      </section>
    </main>

    <script id="brzPublishingBootstrap" type="application/json"><%- bootstrapPayloadJson %></script>
    <script src="/public/js/admin/buildrootz-publishing.js" nonce="<%= cspNonce %>" defer></script>
  </body>
</html>
