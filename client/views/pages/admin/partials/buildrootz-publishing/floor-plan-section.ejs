<section class="card shadow-sm mb-4 brz-workflow-section" data-workflow-section="floor-plan-catalog">
  <div class="card-body">
    <div class="mb-3">
      <h2 class="h5 mb-1"><%= sectionMeta.title || 'Floor Plan Pricing & Media' %></h2>
      <p class="small text-muted mb-0"><%= sectionMeta.subtitle || 'Validate default plan pricing, visibility, and media.' %></p>
    </div>

    <p class="small text-muted mb-3">
      Default Base Price (fallback): if a community-specific price is set, that community value is used instead.
    </p>

    <div class="row g-2 align-items-end mb-3">
      <div class="col-12 col-lg-5">
        <label class="form-label mb-1" for="brzFloorPlanSearch">Search plans</label>
        <input
          id="brzFloorPlanSearch"
          type="search"
          class="form-control form-control-sm"
          placeholder="Search by plan name, plan number, or community"
        />
      </div>
      <div class="col-12 col-md-6 col-lg-4">
        <label class="form-label mb-1" for="brzFloorPlanCommunityFilter">Community</label>
        <select id="brzFloorPlanCommunityFilter" class="form-select form-select-sm">
          <option value="all">All communities</option>
        </select>
      </div>
      <div class="col-12 col-md-6 col-lg-3">
        <label class="form-label mb-1" for="brzFloorPlanIncludeFilter">Include status</label>
        <select id="brzFloorPlanIncludeFilter" class="form-select form-select-sm">
          <option value="all">All plans</option>
          <option value="included">Included only</option>
          <option value="excluded">Excluded only</option>
        </select>
      </div>
      <div class="col-12">
        <div class="small text-muted" id="brzFloorPlanFilterSummary"></div>
      </div>
    </div>

    <div class="table-responsive">
      <table class="table table-sm align-middle">
        <thead>
          <tr>
            <th>Plan</th>
            <th>Community</th>
            <th>Include</th>
            <th>Description Override</th>
            <th>Default Base Price (fallback)</th>
            <th>Primary Image</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody id="brzFloorPlansBody">
          <tr>
            <td colspan="7" class="text-muted">Loading floor plans...</td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</section>
