  <div class="d-flex flex-wrap justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Community Management</h1>
    <div class="btn-group cm-tab-buttons" role="group" aria-label="Community management tabs">
      <button type="button" class="btn btn-outline-primary active" data-tab-target="cm-create-tab">Create New Community</button>
      <button type="button" class="btn btn-outline-primary" data-tab-target="cm-manage-tab">Manage Existing Community</button>
    </div>
  </div>

  <div class="community-management-layout">
    <section class="cm-create tab-panel" id="cm-create-tab">
      <div class="cm-card">
        <h2 class="h5 mb-3">Import Communities from Excel/CSV</h2>
        <form id="importForm" enctype="multipart/form-data" method="POST" action="/api/communities/import">
          <div id="importDropzone" class="dropzone" tabindex="0" aria-label="Upload CSV or XLSX by drag and drop">
            <div class="dz-inner">
              <div class="dz-icon">📄</div>
              <div class="dz-text">
                <strong>Drag & drop</strong> your .csv or .xlsx here<br/>
                or <button type="button" id="browseBtn" class="btn btn-link p-0 align-baseline">browse</button>
              </div>
            </div>
            <input type="file" id="importFile" name="file" accept=".csv,.xlsx" hidden required />
          </div>

          <div class="dz-meta mt-2">
            <span id="fileName" class="text-muted">No file selected</span>
          </div>

          <div class="mt-3 d-flex flex-wrap gap-2">
            <button type="submit" class="btn btn-primary" id="uploadBtn" disabled>Upload</button>
            <a href="/assets/samples/community-import-sample.csv" class="btn btn-outline-secondary">Download sample CSV</a>
          </div>

          <div class="progress mt-2 d-none" id="uploadProgress" aria-hidden="true">
            <div class="progress-bar" role="progressbar" style="width: 0%"></div>
          </div>

          <div id="importMessage" class="alert d-none mt-3" role="status"></div>
        </form>

        <div id="importDecisionModal" class="cm-import-modal" hidden>
          <div class="cm-import-modal__backdrop" data-import-modal-close></div>
          <div class="cm-import-modal__dialog" role="dialog" aria-modal="true" aria-labelledby="importDecisionTitle">
            <div class="cm-import-modal__header">
              <div>
                <p class="text-uppercase text-muted small fw-semibold mb-1">Import Decision</p>
                <h3 class="h5 mb-0" id="importDecisionTitle">Existing community match detected</h3>
              </div>
              <button type="button" class="btn-close" aria-label="Close" data-import-modal-close></button>
            </div>
            <div class="cm-import-modal__body">
              <p class="text-muted mb-3" id="importDecisionIntro">
                Review the imported community details and choose how to continue.
              </p>
              <div id="importDecisionDetails"></div>
            </div>
            <div class="cm-import-modal__footer">
              <button type="button" class="btn btn-outline-secondary" id="importCancelBtn" data-import-modal-close>Cancel</button>
              <button type="button" class="btn btn-outline-primary" id="importCreateNewBtn">Create New Community Anyway</button>
              <button type="button" class="btn btn-primary" id="importAppendBtn">Add Lots to Existing Community</button>
            </div>
          </div>
        </div>
      </div>

      <hr class="cm-divider" />

      <div class="cm-split">
        <div class="cm-card">
          <h2 class="h5 mb-3">Add New Community</h2>
          <form id="community-form" class="cm-form">
            <label class="form-label">Community Name
              <input type="text" id="communityName" class="form-control" required />
            </label>
            <label class="form-label">Project Number
              <input type="text" id="projectNumber" class="form-control" required />
            </label>
            <div class="mt-2">
              <button type="submit" class="btn btn-primary">Create Community</button>
            </div>
          </form>
        </div>

        <div class="cm-card">
          <h2 class="h5 mb-3">Add Lot to Community</h2>
          <form id="lotForm" class="cm-form">
            <label class="form-label">Community
              <select id="communitySelect" class="form-select" required></select>
            </label>
            <div class="cm-field-pair">
              <label class="form-label">Job Number
                <input type="text" id="jobNumber" class="form-control" required />
              </label>
              <label class="form-label">Address
                <input type="text" id="address" class="form-control" required />
              </label>
            </div>
            <div class="cm-field-pair">
              <label class="form-label">Lot
                <input type="text" id="lot" class="form-control" required />
              </label>
              <label class="form-label">Block
                <input type="text" id="block" class="form-control" required />
              </label>
              <label class="form-label">Phase
                <input type="text" id="phase" class="form-control" required />
              </label>
            </div>
            <div class="cm-field-pair">
              <label class="form-label">Floor Plan
                <input type="text" id="floorPlan" class="form-control" />
              </label>
              <label class="form-label">Elevation
                <input type="text" id="elevation" class="form-control" />
              </label>
            </div>
            <div class="mt-2">
              <button type="submit" class="btn btn-primary">Add Lot</button>
            </div>
          </form>
        </div>
      </div>
    </section>

    <section class="cm-card cm-table-card tab-panel" id="cm-manage-tab" style="display:none;">
      <div class="d-flex flex-wrap justify-content-between align-items-center mb-3 gap-2">
        <div>
          <h2 class="h5 mb-1">Lots by Community</h2>
          <p class="text-muted small mb-0">Search, edit, or delete lots for a selected community.</p>
        </div>
      </div>

      <div class="cm-toolbar d-flex flex-wrap align-items-center gap-2 mb-3">
        <label class="me-2 mb-0 cm-toolbar-field">
          <span class="me-1">Community</span>
          <select id="cm-community-filter" class="form-select form-select-sm"></select>
        </label>

        <label class="mb-0 cm-toolbar-field cm-toolbar-field--search">
          <span class="visually-hidden">Search address</span>
          <input id="cm-lot-search" class="form-control form-control-sm" placeholder="Search address..." />
        </label>

        <div class="vr mx-2 d-none d-md-block"></div>

        <button id="cm-edit-toggle" class="btn btn-sm btn-secondary" aria-pressed="false">Edit Mode</button>
        <button id="cm-delete-toggle" class="btn btn-sm btn-danger" aria-pressed="false">Delete Mode</button>
        <small class="text-muted ms-2">Tip: Edit cells then press Enter/blur to save.</small>

        <div class="ms-auto d-flex flex-wrap align-items-center gap-2">
          <button id="cm-export-csv" type="button" class="btn btn-sm btn-outline-primary">Export CSV</button>
          <button id="deleteCommunityBtn" type="button" class="btn btn-sm btn-outline-danger">Delete Community</button>
        </div>
      </div>

      <div id="lotsContainer"></div>
    </section>
  </div>

  <script type="module" src="/assets/js/pages/admin/community-management/index.js" nonce="<%= cspNonce %>"></script>
  <script nonce="<%= cspNonce %>">
    

    (() => {
  const dz = document.getElementById('importDropzone');
  const fileInput = document.getElementById('importFile');
  const browseBtn = document.getElementById('browseBtn');
  const fileName = document.getElementById('fileName');
  const uploadBtn = document.getElementById('uploadBtn');
  const importForm = document.getElementById('importForm');
  const progressWrap = document.getElementById('uploadProgress');
  const progressBar = progressWrap ? progressWrap.querySelector('.progress-bar') : null;
  const importMessage = document.getElementById('importMessage');
  const importModal = document.getElementById('importDecisionModal');
  const importDecisionDetails = document.getElementById('importDecisionDetails');
  const importDecisionIntro = document.getElementById('importDecisionIntro');
  const importAppendBtn = document.getElementById('importAppendBtn');
  const importCreateNewBtn = document.getElementById('importCreateNewBtn');
  const modalCloseButtons = importModal ? importModal.querySelectorAll('[data-import-modal-close]') : [];

  window.cmImportFile = null;
  let pendingImportToken = '';
  let pendingImportPreviews = [];

  if (!dz || !fileInput || !browseBtn || !fileName || !uploadBtn || !importForm) return;

  // Helpers
  const prevent = e => { e.preventDefault(); e.stopPropagation(); };
  const esc = value => String(value ?? '').replace(/[&<>"]/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c]));
  const showImportMessage = (message, variant = 'info') => {
    if (!importMessage) return;
    importMessage.className = `alert alert-${variant} mt-3`;
    importMessage.textContent = message;
    importMessage.classList.remove('d-none');
  };
  const hideImportMessage = () => {
    if (!importMessage) return;
    importMessage.className = 'alert d-none mt-3';
    importMessage.textContent = '';
  };
  const closeImportModal = () => {
    if (!importModal) return;
    importModal.hidden = true;
    pendingImportToken = '';
    pendingImportPreviews = [];
  };
  const openImportModal = (payload) => {
    if (!importModal || !importDecisionDetails) return;
    pendingImportToken = payload?.token || '';
    pendingImportPreviews = Array.isArray(payload?.previews) ? payload.previews : [];

    const matchedPreviews = pendingImportPreviews.filter(preview => preview?.matchedCommunity);
    const intro = matchedPreviews.length > 1
      ? `This file contains ${matchedPreviews.length} imported community groups that appear to match existing communities.`
      : 'A likely existing community match was found for this import.';
    if (importDecisionIntro) importDecisionIntro.textContent = intro;

    importDecisionDetails.innerHTML = pendingImportPreviews.map((preview) => {
      const importedLabel = esc(preview.importedCommunityName || 'Imported Community');
      const importedProject = preview.projectNumber ? `Project #: ${esc(preview.projectNumber)}` : 'Project #: --';
      const importedLocation = [preview.city, preview.state].filter(Boolean).map(esc).join(', ') || '--';
      const matched = preview.matchedCommunity;
      const matchedMarkup = matched
        ? `
          <div class="cm-import-match-card is-match">
            <div>
              <p class="cm-import-match-card__label">Matched Existing Community</p>
              <strong>${esc(matched.name || '--')}</strong>
            </div>
            <div class="cm-import-match-card__meta">
              <span>${matched.projectNumber ? `Project #: ${esc(matched.projectNumber)}` : 'Project #: --'}</span>
              <span>Existing lots: ${Number(matched.lotCount || 0)}</span>
            </div>
          </div>
        `
        : `
          <div class="cm-import-match-card">
            <div>
              <p class="cm-import-match-card__label">Matched Existing Community</p>
              <strong>No likely match found</strong>
            </div>
            <div class="cm-import-match-card__meta">
              <span>This group will create a new community either way.</span>
            </div>
          </div>
        `;

      return `
        <section class="cm-import-preview">
          <div class="cm-import-match-card is-imported">
            <div>
              <p class="cm-import-match-card__label">Imported Community</p>
              <strong>${importedLabel}</strong>
            </div>
            <div class="cm-import-match-card__meta">
              <span>${importedProject}</span>
              <span>Location: ${importedLocation}</span>
              <span>Imported lots: ${Number(preview.importedLotCount || 0)}</span>
            </div>
          </div>
          ${matchedMarkup}
        </section>
      `;
    }).join('');

    importModal.hidden = false;
  };
  const buildSummaryMessage = (summary) => {
    if (!summary) return 'Import finished.';
    const parts = [];
    if (Number(summary.importedLots || 0)) parts.push(`${summary.importedLots} lots imported`);
    if (Number(summary.duplicatesSkipped || 0)) parts.push(`${summary.duplicatesSkipped} duplicates skipped`);
    if (Number(summary.communitiesCreated || 0)) {
      parts.push(`${summary.communitiesCreated} ${summary.communitiesCreated === 1 ? 'community' : 'communities'} created`);
    }
    if (Number(summary.communitiesUpdated || 0)) {
      parts.push(`${summary.communitiesUpdated} existing ${summary.communitiesUpdated === 1 ? 'community' : 'communities'} updated`);
    }
    return parts.length ? parts.join(' • ') : 'Import finished.';
  };
  const finalizeImportSuccess = (summary) => {
    setFile(null);
    closeImportModal();
    showImportMessage(buildSummaryMessage(summary), summary?.duplicatesSkipped ? 'warning' : 'success');
    document.dispatchEvent(new CustomEvent('cm:communitiesImported'));
  };
  const confirmImportAction = async (action) => {
    if (!pendingImportToken) return;
    importAppendBtn.disabled = true;
    importCreateNewBtn.disabled = true;
    try {
      const res = await fetch('/api/communities/import/confirm', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ token: pendingImportToken, action })
      });
      const payload = await res.json().catch(() => null);
      if (!res.ok) {
        throw new Error(payload?.error || `Import confirm failed (${res.status})`);
      }
      finalizeImportSuccess(payload?.summary);
    } catch (err) {
      console.error('[community-import:confirm]', err);
      showImportMessage(err.message || 'Import confirm failed.', 'danger');
    } finally {
      importAppendBtn.disabled = false;
      importCreateNewBtn.disabled = false;
    }
  };
  const setFile = f => {
    if (!f) {
      window.cmImportFile = null;
      if (fileInput) fileInput.value = '';
      fileName.textContent = 'No file selected';
      uploadBtn.disabled = true;
      return;
    }

    window.cmImportFile = f;

    if ('DataTransfer' in window) {
      try {
        const dt = new DataTransfer();
        dt.items.add(f);
        fileInput.files = dt.files;
      } catch (err) {
        console.warn('Unable to sync file input', err);
      }
    }

    fileName.textContent = `${f.name} - ${(f.size / 1024).toFixed(1)} KB`;
    uploadBtn.disabled = false;
  };

  // Drag events
  ['dragenter','dragover','dragleave','drop'].forEach(evt => {
    dz.addEventListener(evt, prevent, false);
  });
  ['dragenter','dragover'].forEach(evt => {
    dz.addEventListener(evt, () => dz.classList.add('drag'), false);
  });
  ['dragleave','drop'].forEach(evt => {
    dz.addEventListener(evt, () => dz.classList.remove('drag'), false);
  });
  dz.addEventListener('drop', e => {
    const files = e.dataTransfer.files;
    if (files && !('DataTransfer' in window)) {
      try { fileInput.files = files; } catch (_) {}
    }
    setFile(files && files[0]);
  });

  // Keyboard + click browse
  dz.addEventListener('click', () => fileInput.click());
  dz.addEventListener('keydown', e => {
    if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); fileInput.click(); }
  });
  browseBtn.addEventListener('click', () => fileInput.click());
  fileInput.addEventListener('change', () => {
    const f = fileInput.files && fileInput.files[0];
    hideImportMessage();
    setFile(f);
  });

  modalCloseButtons.forEach((button) => {
    button.addEventListener('click', () => closeImportModal());
  });
  importAppendBtn?.addEventListener('click', () => confirmImportAction('append'));
  importCreateNewBtn?.addEventListener('click', () => confirmImportAction('create_new'));

  importForm.addEventListener('submit', async (event) => {
    event.preventDefault();
    if (!window.cmImportFile) {
      alert('Select a CSV or XLSX file first.');
      return;
    }
    hideImportMessage();

    const formData = new FormData();
    formData.append('file', window.cmImportFile);

    const originalLabel = uploadBtn.textContent;
    uploadBtn.disabled = true;
    uploadBtn.textContent = 'Uploading...';
    if (progressWrap) {
      progressWrap.classList.remove('d-none');
      progressWrap.setAttribute('aria-hidden', 'false');
      if (progressBar) progressBar.style.width = '30%';
    }

    try {
      const res = await fetch(importForm.action || '/api/communities/import', {
        method: 'POST',
        body: formData
      });
      if (!res.ok) {
        const payload = await res.json().catch(() => null);
        throw new Error(payload?.error || `Upload failed (${res.status})`);
      }

      const payload = await res.json().catch(() => null);

      if (progressBar) progressBar.style.width = '100%';

      if (payload?.requiresDecision) {
        openImportModal(payload);
        return;
      }

      finalizeImportSuccess(payload?.summary);
    } catch (err) {
      console.error('[community-import]', err);
      showImportMessage(err.message || 'Upload failed.', 'danger');
    } finally {
      uploadBtn.disabled = false;
      uploadBtn.textContent = originalLabel;
      if (progressWrap) {
        progressWrap.classList.add('d-none');
        progressWrap.setAttribute('aria-hidden', 'true');
      }
      if (progressBar) progressBar.style.width = '0%';
    }
  });

  // OPTIONAL: show progress if you intercept the submit with XHR
  // If your backend expects a regular form POST, you can skip this block and let
  // your existing handler submit. Otherwise, uncomment to POST with progress.
  
})();

document.addEventListener('DOMContentLoaded', () => {
  const esc = s => String(s ?? '').replace(/[&<>"]/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c]));
  const $ = sel => document.querySelector(sel);
  const communitySel = $('#cm-community-filter');
  const searchInput  = $('#cm-lot-search');
  const editBtn      = $('#cm-edit-toggle');
  const delBtn       = $('#cm-delete-toggle');
  const lotsWrap     = $('#lotsContainer');
  const exportBtn    = $('#cm-export-csv');
  const deleteCommunityBtn = $('#deleteCommunityBtn');
  const tabButtons = document.querySelectorAll('[data-tab-target]');
  const tabPanels = document.querySelectorAll('.tab-panel');

  let state = {
    communities: [],
    communityId: null,
    search: '',
    editMode: false,
    deleteMode: false
  };

  // --------- load communities (for dropdown) ----------
  async function loadCommunities() {
    if (deleteCommunityBtn) deleteCommunityBtn.disabled = true;
    const res = await fetch('/api/communities');
    if (!res.ok) throw new Error('Failed to load communities');
    const items = await res.json();
    state.communities = Array.isArray(items) ? items : [];
    if (!communitySel) return;

    communitySel.innerHTML = state.communities.map(c =>
      `<option value="${c._id}">${esc(c.name)}${c.projectNumber ? ' ??? ' + esc(c.projectNumber) : ''}</option>`
    ).join('');

    if (!state.communities.length) {
      state.communityId = null;
      communitySel.value = '';
      if (deleteCommunityBtn) deleteCommunityBtn.disabled = true;
      return;
    }

    const stillValid = state.communityId && state.communities.some(c => c._id === state.communityId);
    state.communityId = stillValid ? state.communityId : state.communities[0]._id;
    communitySel.value = state.communityId;
    if (deleteCommunityBtn) deleteCommunityBtn.disabled = !state.communityId;
  }
  // --------- load/render lots for selected community ----------
  async function loadLots() {
    if (!state.communityId) {
      lotsWrap.innerHTML = '<div class="text-muted">Select a community</div>';
      return;
    }
    const url = new URL(`/api/communities/${state.communityId}/lots`, location.origin);
    if (state.search) url.searchParams.set('q', state.search);
    const res = await fetch(url);
    if (!res.ok) {
      lotsWrap.innerHTML = `<div class="text-danger">Failed to load lots (${res.status})</div>`;
      return;
    }
    const lots = await res.json();
    renderTable(Array.isArray(lots) ? lots : []);
  }

  function renderTable(lots) {
    const deleteCol = state.deleteMode ? '<th style="width:42px"></th>' : '';
    const head = `
      <thead>
        <tr>
          <th>Job #</th>
          <th>Lot</th>
          <th>Block</th>
          <th>Phase</th>
          <th>Address</th>
          <th>Elevation</th>
          ${deleteCol}
        </tr>
      </thead>
    `;

    const rows = lots.map(l => {
      const delCell = state.deleteMode
        ? `<td class="text-center"><button class="btn btn-sm btn-outline-danger js-row-del" data-id="${esc(l._id)}" title="Delete this lot">??</button></td>`
        : '';
      return `
        <tr data-id="${esc(l._id)}">
          ${td('jobNumber', l.jobNumber)}
          ${td('lot', l.lot)}
          ${td('block', l.block)}
          ${td('phase', l.phase)}
          ${td('address', l.address)}
          ${td('elevation', l.elevation)}
          ${delCell}
        </tr>
      `;
    }).join('') || `<tr><td colspan="${state.deleteMode ? 7 : 6}" class="text-muted">No lots found</td></tr>`;

    lotsWrap.innerHTML = `
      <div class="table-responsive">
        <table class="table table-sm table-bordered align-middle mb-0">
          ${head}
          <tbody>${rows}</tbody>
        </table>
      </div>
    `;

    // attach events: edit + delete
    if (state.editMode) bindCellEditing(lotsWrap);
    if (state.deleteMode) bindRowDeletion(lotsWrap);
  }

  function td(field, val) {
    const attrs = state.editMode ? ' contenteditable="true" data-field="'+field+'"' : ' data-field="'+field+'"';
    return `<td${attrs}>${esc(val ?? '')}</td>`;
  }

  function bindCellEditing(root) {
    // Save on Enter or on blur if changed
    root.querySelectorAll('td[contenteditable="true"]').forEach(td => {
      td.addEventListener('keydown', async (e) => {
        if (e.key === 'Enter') { e.preventDefault(); td.blur(); }
      });
      td.addEventListener('blur', async (e) => {
        const tr = td.closest('tr');
        const lotId = tr?.dataset?.id;
        const field = td.dataset.field;
        if (!lotId || !field) return;

        const newValue = td.textContent.trim();

        // build minimal payload of changed field
        const payload = { [field]: newValue };
        // normalize/guards for a couple of fields
        if (field === 'jobNumber') payload.jobNumber = String(newValue).padStart(4, '0');

        try {
          const res = await fetch(`/api/communities/${state.communityId}/lots/${lotId}`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
          });
          if (!res.ok) {
            alert(`Save failed (${res.status})`);
            // re-load to revert bad edit
            await loadLots();
          }
        } catch (err) {
          console.error(err);
          alert('Save failed');
          await loadLots();
        }
      });
    });
  }

  function bindRowDeletion(root) {
    root.querySelectorAll('.js-row-del').forEach(btn => {
      btn.addEventListener('click', async () => {
        const lotId = btn.dataset.id;
        if (!lotId) return;
        if (!confirm('Delete this lot? This cannot be undone.')) return;

        try {
          const res = await fetch(`/api/communities/${state.communityId}/lots/${lotId}`, { method: 'DELETE' });
          if (!res.ok) {
            const t = await res.text();
            throw new Error(t || `Delete failed (${res.status})`);
          }
          await loadLots();
        } catch (err) {
          console.error(err);
          alert(err.message || 'Delete failed');
        }
      });
    });
  }

  // --------- events ----------
  communitySel?.addEventListener('change', () => {
    state.communityId = communitySel.value || null;
    if (deleteCommunityBtn) deleteCommunityBtn.disabled = !state.communityId;
    loadLots();
  });

  // debounce search
  let t;
  searchInput?.addEventListener('input', () => {
    clearTimeout(t);
    t = setTimeout(() => {
      state.search = searchInput.value.trim();
      loadLots();
    }, 250);
  });

  editBtn?.addEventListener('click', async () => {
    state.editMode = !state.editMode;
    editBtn.classList.toggle('btn-secondary', !state.editMode);
    editBtn.classList.toggle('btn-success', state.editMode);
    editBtn.setAttribute('aria-pressed', String(state.editMode));
    await loadLots();
  });

  delBtn?.addEventListener('click', async () => {
    state.deleteMode = !state.deleteMode;
    delBtn.classList.toggle('btn-danger', !state.deleteMode);
    delBtn.classList.toggle('btn-warning', state.deleteMode);
    delBtn.setAttribute('aria-pressed', String(state.deleteMode));
    await loadLots();
  });
  exportBtn?.addEventListener('click', async () => {
    if (!state.communityId) {
      alert('Select a community first');
      return;
    }

    try {
      const url = new URL(`/api/communities/${state.communityId}/lots`, location.origin);
      if (state.search) url.searchParams.set('q', state.search);
      url.searchParams.set('format', 'csv');

      const res = await fetch(url, { headers: { Accept: 'text/csv' } });
      const text = await res.text();
      if (!res.ok) throw new Error(text || `Export failed (${res.status})`);

      const blob = new Blob([text], { type: 'text/csv' });
      const dlUrl = window.URL.createObjectURL(blob);
      const link = document.createElement('a');
      const name = (state.communities.find(c => c._id === state.communityId)?.name || 'community')
        .replace(/[^a-z0-9]+/gi, '-')
        .replace(/^-+|-+$/g, '') || 'community';
      link.href = dlUrl;
      link.download = `${name}-lots.csv`;
      document.body.appendChild(link);
      link.click();
      link.remove();
      window.URL.revokeObjectURL(dlUrl);
    } catch (err) {
      console.error(err);
      alert(err.message || 'Export failed');
    }
  });
  deleteCommunityBtn?.addEventListener('click', async () => {
    if (!state.communityId) {
      alert('Select a community first');
      return;
    }

    const current = state.communities.find(c => c._id === state.communityId);
    const label = current?.name ? current.name : 'this community';
    if (!confirm(`Delete "${label}"? All lots under this community will be removed.`)) return;

    try {
      const res = await fetch(`/api/communities/${state.communityId}`, { method: 'DELETE' });
      const text = await res.text();
      if (!res.ok) throw new Error(text || `Delete failed (${res.status})`);
      await loadCommunities();
      await loadLots();
      alert('Community deleted.');
    } catch (err) {
      console.error(err);
      alert(err.message || 'Delete failed');
    }
  });

  // Tabs (Create vs Manage)
  const activateTab = (id) => {
    tabPanels.forEach((panel) => {
      panel.style.display = panel.id === id ? '' : 'none';
    });
    tabButtons.forEach((btn) => {
      const isActive = btn.getAttribute('data-tab-target') === id;
      btn.classList.toggle('active', isActive);
    });
  };
  tabButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const target = btn.getAttribute('data-tab-target') || 'cm-create-tab';
      activateTab(target);
    });
  });
  activateTab('cm-create-tab');

  // --------- boot ----------
  (async () => {
    await loadCommunities();
    await loadLots();
  })();
});
  </script>
